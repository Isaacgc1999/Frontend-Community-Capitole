---
// Atrium · Card
// A general-purpose content card — replaces Starlight's built-in <Card>.
// Use inside <CardGrid> or standalone.
//
// Props:
//   title:    string        card heading
//   href:     string         optional — turns the card into a link
//   icon:     string         optional emoji/text icon (or use the `icon` slot for SVGs)
//   variant:  "default" | "outline" | "solid" | "accent"
//
// Slots:
//   icon     — overrides the `icon` prop (use for inline SVG)
//   default  — body copy
//   footer   — optional footer line (mono · muted)

interface Props {
  title: string;
  href?: string;
  icon?: string;
  variant?: 'default' | 'outline' | 'solid' | 'accent';
}
const { title, href, icon, variant = 'default' } = Astro.props;
const Tag = href ? 'a' : 'div';
const tagProps = href ? { href } : {};
const hasIcon = icon || Astro.slots.has('icon');
---
<Tag class:list={['atrium-card', `atrium-card--${variant}`, href && 'is-link']} {...tagProps}>
  {hasIcon && (
    <div class="atrium-card__icon">
      <slot name="icon">{icon}</slot>
    </div>
  )}
  <div class="atrium-card__body">
    <h3 class="atrium-card__title">{title}</h3>
    <div class="atrium-card__text"><slot /></div>
  </div>
  {Astro.slots.has('footer') && (
    <div class="atrium-card__footer"><slot name="footer" /></div>
  )}
  {href && <span class="atrium-card__chev" aria-hidden="true">→</span>}
</Tag>

<style>
  .atrium-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: var(--atrium-s-4);
    row-gap: var(--atrium-s-3);
    align-items: start;
    background: var(--atrium-bg-elev);
    border: 1px solid var(--atrium-border);
    border-radius: var(--atrium-r-md);
    padding: var(--atrium-s-6);
    color: var(--atrium-fg);
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }
  .atrium-card.is-link:hover {
    border-color: var(--atrium-ink-300);
  }
  .atrium-card.is-link:hover .atrium-card__chev {
    transform: translateX(3px);
    color: var(--atrium-accent);
  }

  .atrium-card__icon {
    grid-row: 1 / span 2;
    width: 36px; height: 36px;
    border-radius: var(--atrium-r-sm);
    background: var(--atrium-ink-900);
    color: var(--atrium-paper);
    display: grid; place-items: center;
    font-size: 16px;
    flex: none;
  }

  .atrium-card__body {
    grid-column: 2;
    display: grid;
    gap: var(--atrium-s-2);
  }

  .atrium-card__title {
    font-size: var(--atrium-fs-18);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: inherit;
    line-height: 1.25;
  }

  .atrium-card__text {
    font-size: var(--atrium-fs-14);
    line-height: 1.55;
    color: var(--atrium-fg-muted);
  }
  .atrium-card__text :global(p) { margin: 0 0 var(--atrium-s-2); }
  .atrium-card__text :global(p:last-child) { margin-bottom: 0; }
  .atrium-card__text :global(a) { color: var(--atrium-accent); }

  .atrium-card__footer {
    grid-column: 2 / -1;
    margin-top: var(--atrium-s-2);
    padding-top: var(--atrium-s-3);
    border-top: 1px solid var(--atrium-border);
    font-family: var(--atrium-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--atrium-fg-subtle);
  }

  .atrium-card__chev {
    grid-column: 3;
    grid-row: 1;
    align-self: start;
    font-family: var(--atrium-font-mono);
    color: var(--atrium-fg-subtle);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  /* Variants */
  .atrium-card--outline {
    background: transparent;
  }

  .atrium-card--solid {
    background: var(--atrium-ink-900);
    border-color: var(--atrium-ink-900);
    color: var(--atrium-paper);
  }
  .atrium-card--solid .atrium-card__icon {
    background: var(--atrium-ink-700);
    color: var(--atrium-paper);
  }
  .atrium-card--solid .atrium-card__text { color: var(--atrium-ink-200); }
  .atrium-card--solid .atrium-card__footer {
    color: var(--atrium-ink-300);
    border-color: var(--atrium-ink-700);
  }
  .atrium-card--solid .atrium-card__chev { color: var(--atrium-ink-300); }
  .atrium-card--solid.is-link:hover { border-color: var(--atrium-blue-500); }

  .atrium-card--accent {
    background: rgba(46, 84, 200, 0.06);
    border-color: rgba(46, 84, 200, 0.20);
  }
  .atrium-card--accent .atrium-card__icon {
    background: var(--atrium-accent);
    color: var(--atrium-paper);
  }
  .atrium-card--accent .atrium-card__title { color: var(--atrium-accent); }

  /* Responsive: collapse icon column when card is narrow */
  @media (max-width: 480px) {
    .atrium-card { grid-template-columns: 1fr auto; }
    .atrium-card__icon { grid-row: 1; grid-column: 1; }
    .atrium-card__body { grid-column: 1 / -1; }
  }
</style>
