---
import Button from './Button.astro';

interface Props {
  tagline?: string;
}
const { tagline = '' } = Astro.props;
---
<section class="hero">
  {tagline && <p class="hero__tagline">{tagline}</p>}
  <div class="hero__actions">
    <Button href="/docs/" intent="primary" size="lg" showArrow>Get started</Button>
    <Button
      href="https://github.com/IsaacGarcia-Capitole/Frontend-Community-Capitole"
      intent="secondary"
      size="lg"
    >
      View on GitHub
    </Button>
  </div>
</section>

<style>
  .hero {
    padding: var(--atrium-s-12) 0 var(--atrium-s-10);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--atrium-s-6);
  }
  .hero__tagline {
    font-size: var(--atrium-fs-20);
    color: var(--atrium-fg-muted);
    max-width: 56ch;
    line-height: 1.5;
    margin: 0;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--atrium-s-3);
  }
</style>
