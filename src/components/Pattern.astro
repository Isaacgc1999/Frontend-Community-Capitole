---
// Atrium · Pattern
// Reusable geometric SVG patterns. Use as decorative imagery inside cards or hero blocks.
//
// Props:
//   kind: "orbit" | "facet" | "trend" | "grid"  (default "orbit")
//   dark: boolean — if true, uses dark surface
//   width / height: passthrough sizing

interface Props {
  kind?: 'orbit' | 'facet' | 'trend' | 'grid';
  dark?: boolean;
  width?: string | number;
  height?: string | number;
}
const { kind = 'orbit', dark = false, width = '100%', height = '100%' } = Astro.props;
const bg = dark ? '#0B1220' : '#F5F4EE';
const stroke = dark ? '#3B82F6' : '#1E40AF';
const strokeFaint = dark ? 'rgba(59,130,246,0.4)' : 'rgba(11,18,32,0.18)';
---
<svg viewBox="0 0 200 200" width={width} height={height} preserveAspectRatio="xMidYMid slice" aria-hidden="true">
  <rect width="200" height="200" fill={bg} />

  {kind === 'orbit' && (
    <g>
      <circle cx="100" cy="100" r="70" fill="none" stroke={stroke} stroke-width="1.5" />
      <circle cx="100" cy="100" r="40" fill="none" stroke={stroke} stroke-width="1.5" />
      <circle cx="100" cy="100" r="12" fill={stroke} />
      <line x1="0" y1="100" x2="200" y2="100" stroke={strokeFaint} />
      <line x1="100" y1="0" x2="100" y2="200" stroke={strokeFaint} />
    </g>
  )}

  {kind === 'facet' && (
    <g stroke={dark ? stroke : '#0B1220'} stroke-opacity={dark ? 0.7 : 0.35} stroke-width="1" fill="none">
      <path d="M0 100 L100 0 L200 100 L100 200 Z" />
      <path d="M30 100 L100 30 L170 100 L100 170 Z" />
      <path d="M60 100 L100 60 L140 100 L100 140 Z" />
      <circle cx="100" cy="100" r="6" fill={stroke} stroke="none" />
    </g>
  )}

  {kind === 'trend' && (
    <g>
      <g stroke={strokeFaint} stroke-width="1">
        <line x1="0" y1="40"  x2="200" y2="40" />
        <line x1="0" y1="80"  x2="200" y2="80" />
        <line x1="0" y1="120" x2="200" y2="120" />
        <line x1="0" y1="160" x2="200" y2="160" />
      </g>
      <path d="M0 130 L40 110 L80 140 L120 70 L160 100 L200 60"
            fill="none" stroke={stroke} stroke-width="1.5" />
      <circle cx="120" cy="70" r="3" fill={stroke} />
    </g>
  )}

  {kind === 'grid' && (
    <g stroke={dark ? stroke : '#0B1220'} stroke-width="1" stroke-opacity={dark ? 0.5 : 0.6} fill="none">
      <rect x="20"  y="20"  width="60" height="60" />
      <rect x="120" y="20"  width="60" height="60" />
      <rect x="20"  y="120" width="60" height="60" />
      <rect x="120" y="120" width="60" height="60" />
      <line x1="80"  y1="50"  x2="120" y2="50" />
      <line x1="50"  y1="80"  x2="50"  y2="120" />
      <line x1="150" y1="80"  x2="150" y2="120" />
      <line x1="80"  y1="150" x2="120" y2="150" />
      <circle cx="100" cy="100" r="6" fill={stroke} stroke="none" />
    </g>
  )}
</svg>
